  - transformation_function
author: "Sean Chatman"
mode: overwrite
---


{% if artifact_type == 'powl' -%}
# {{ artifact_name | title }} - Process OWL (POWL) Artifact
# Generated from OStar ProjectedArtifact ontology
# Artifact Type: POWL (Process Ontology Web Language)
# Transformation: {{ transformation_function }}

@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>.
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#>.
@prefix powl: <http://www.example.org/powl#>.
@prefix {{ prefix_namespace }}: <{{ namespace_uri }}>.
@prefix xsd: <http://www.w3.org/2001/XMLSchema#>.

# Process Definition
{{ prefix_namespace }}:{{ artifact_name | camelCase }}Process a powl:Process ;
    rdfs:label "{{ artifact_name | title }}" ;
    powl:hasInput {{ prefix_namespace }}:{{ artifact_name | camelCase }}Input ;
    powl:hasOutput {{ prefix_namespace }}:{{ artifact_name | camelCase }}Output ;
    powl:hasControlFlow {{ prefix_namespace }}:{{ artifact_name | camelCase }}Flow .

# Input Schema
{{ prefix_namespace }}:{{ artifact_name | camelCase }}Input a powl:Input ;
    rdfs:label "{{ artifact_name }} Input" ;
    powl:hasParameter {% for param in input_parameters -%}
{{ prefix_namespace }}:{{ param.name | camelCase }}Param ;
    rdfs:label "{{ param.name }}" ;
    powl:dataType "{{ param.xsd_type }}"^^xsd:anyURI {% if not loop.last %},{% endif %}
{% endfor -%}
.

# Output Schema
{{ prefix_namespace }}:{{ artifact_name | camelCase }}Output a powl:Output ;
    rdfs:label "{{ artifact_name }} Output" ;
    powl:hasParameter {% for param in output_parameters -%}
{{ prefix_namespace }}:{{ param.name | camelCase }}Param ;
    rdfs:label "{{ param.name }}" ;
    powl:dataType "{{ param.xsd_type }}"^^xsd:anyURI {% if not loop.last %},{% endif %}
{% endfor -%}
.

# Control Flow
{{ prefix_namespace }}:{{ artifact_name | camelCase }}Flow a powl:Sequence ;
    powl:hasStep {% for step in workflow_steps -%}
{{ prefix_namespace }}:{{ step.name | camelCase }}Step ;
    powl:order {{ step.order }} ;
    powl:activity {{ step.activity }} {% if not loop.last %},{% endif %}
{% endfor -%}
.

{% elif artifact_type == 'sparql' -%}
# {{ artifact_name | title }} - SPARQL Query Artifact
# Generated from OStar ProjectedArtifact ontology
# Artifact Type: SPARQL
# Transformation: {{ transformation_function }}

PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX {{ prefix_namespace }}: <{{ namespace_uri }}>

# {{ artifact_name | title }}
# Query Type: {{ query_type | default("SELECT") }}
# Purpose: {{ query_purpose }}

{% if query_type == 'CONSTRUCT' -%}
CONSTRUCT {
  ?subject a {{ class_name }} ;
    {{ prefix_namespace }}:name ?name ;
    {{ prefix_namespace }}:description ?description ;
    {{ prefix_namespace }}:generatedAt ?timestamp .
}
WHERE {
  GRAPH $graph_uri {
    ?subject a {{ source_class }} ;
      {{ prefix_namespace }}:name ?name ;
      OPTIONAL { ?subject {{ prefix_namespace }}:description ?description . }
  }

  BIND(NOW() as ?timestamp)
}
{% elif query_type == 'SELECT' -%}
SELECT ?subject ?name ?description
WHERE {
  GRAPH $graph_uri {
    ?subject a {{ class_name }} ;
      {{ prefix_namespace }}:name ?name ;
      OPTIONAL { ?subject {{ prefix_namespace }}:description ?description . }
  }

  {% if filters -%}
  FILTER (
    {% for filter in filters -%}
    {% if filter.type == 'regex' -%}
    regex(?name, "{{ filter.value }}", "i")
    {% elif filter.type == 'range' -%}
    ?{{ filter.property }} >= {{ filter.min }} && ?{{ filter.property }} <= {{ filter.max }}
    {% endif -%}
    {% if not loop.last %}&& {% endif %}
    {% endfor -%}
  )
  {% endif -%}

  LIMIT $limit
  OFFSET $offset
}
{% elif query_type == 'ASK' -%}
ASK {
  GRAPH $graph_uri {
    ?subject a {{ class_name }} ;
      {{ prefix_namespace }}:name ?name .
    FILTER (?name = "{{ entity_name }}")
  }
}
{% elif query_type == 'UPDATE' -%}
DELETE {
  GRAPH $graph_uri {
    ?subject {{ prefix_namespace }}:status ?oldStatus .
  }
}
INSERT {
  GRAPH $graph_uri {
    ?subject {{ prefix_namespace }}:status "{{ new_status }}" ;
      {{ prefix_namespace }}:updatedAt ?timestamp .
  }
}
WHERE {
  GRAPH $graph_uri {
    ?subject a {{ class_name }} ;
      {{ prefix_namespace }}:id "{{ entity_id }}" ;
      {{ prefix_namespace }}:status ?oldStatus .
  }

  BIND(NOW() as ?timestamp)
}
{% endif -%}

{% elif artifact_type == 'shacl' -%}
# {{ artifact_name | title }} - SHACL Shape Artifact
# Generated from OStar ProjectedArtifact ontology
# Artifact Type: SHACL (Shapes Constraint Language)
# Transformation: {{ transformation_function }}

@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>.
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#>.
@prefix sh: <http://www.w3.org/ns/shacl#>.
@prefix xsd: <http://www.w3.org/2001/XMLSchema#>.
@prefix {{ prefix_namespace }}: <{{ namespace_uri }}>.

# Shape Definition
{{ prefix_namespace }}:{{ artifact_name | camelCase }}Shape a sh:NodeShape ;
    rdfs:label "{{ artifact_name | title }} Shape" ;
    sh:targetClass {{ class_name }} ;
    sh:property {% for property in properties -%}
{{ prefix_namespace }}:{{ artifact_name | camelCase }}{{ property.name | camelCase }}Constraint ;
        sh:path {{ prefix_namespace }}:{{ property.name | snakeCase }} ;
        sh:datatype {{ property.xsd_type }} ;
        sh:minCount {{ property.min_count | default(0) }} ;
        sh:maxCount {{ property.max_count | default(1) }} ;
        sh:severity {{ property.severity | default("sh:Violation") }} {% if not loop.last %};{% endif %}
{% endfor -%}
.

{% elif artifact_type == 'mcp-tool' -%}
/**
 * {{ artifact_name | title }} - MCP Tool Artifact
 * Generated from OStar ProjectedArtifact ontology
 * Artifact Type: MCP Tool
 * Transformation: {{ transformation_function }}
 *
 * BREED: {{ breed | default('dachshund') | upper }}
 *
 * HARDENED & COMPLIANT (L4/L5):
 * - Constitutional Admissibility: HardenedAtomVM wrapper
 * - Causal Consistency: VectorClock tracking
 * - Transactional Persistence: appendEvent used
 * - OTel Observability: Spans emitted
 */

{% if breed == 'shepherd' -%}
import { trace } from '@opentelemetry/api';
import { VectorClock, DistributedConsensus } from '@unrdf/kgc-4d';
{% endif -%}
{% if (harden or breed == 'dachshund') -%}
import { HardenedAtomVM } from '@unrdf/atomvm';
import { validate } from '@unrdf/shacl';
{% endif -%}

// WvdA Soundness: Timeout constants
const DEFAULT_TIMEOUT_MS = {{ 30000 if breed == 'shepherd' else 5000 }};
const SPARQL_TIMEOUT_MS = {{ 10000 if breed == 'shepherd' else 2000 }};
const MAX_RESULT_SIZE = {{ 1000 if breed == 'shepherd' else 100 }};

/**
 * WvdA Soundness: OCEL Event Emission
 *
 * @param {string} eventType - OCEL event type
 * @param {object} attributes - Event attributes
 */
function emitOCELEvent(eventType, attributes) {
  {% if breed == 'shepherd' -%}
  // Log OCEL event for persistence
  console.log(JSON.stringify({
    ocel_event: eventType,
    timestamp: new Date().toISOString(),
    attributes: attributes
  }));
  {% else -%}
  // Dachshund: Minimal local-only logging
  if (process.env.VERBOSE) console.log(`[EVENT] ${eventType}`);
  {% endif -%}
}


export const {{ artifact_name | camelCase }}Tool = {
  name: '{{ artifact_name | snakeCase }}',
  description: '{{ tool_description }}',
  category: '{{ tool_category }}',

  inputSchema: {
    type: 'object',
    properties: {
      {% for param in input_parameters -%}
      {{ param.name | camelCase }}: {
        type: '{{ param.type }}',
        description: '{{ param.description }}'
      }{% if not loop.last %},{% endif %}
      {% endfor -%}
    },
    required: [
      {% for req in required_params -%}
      '{{ req | camelCase }}'{% if not loop.last %}, {% endif %}
      {% endfor -%}
    ]
  },

  async handler(input, context) {
    const { {{ required_params | join(', ') }} } = input;
    
    {% if breed == 'shepherd' -%}
    const tracer = trace.getTracer('ostar-mcp-tool');

    return await tracer.startActiveSpan('{{ artifact_name | snakeCase }}.execute', async (span) => {
      try {
        // L5 HARDENING: Initialize Causal Context
        const vc = new VectorClock(context.nodeId || 'ostar-node');
        vc.increment();

        const result = await execute{{ artifact_name | camelCase }}(
          {{ required_params | join(', ') }},
          { ...context, vc }
        );

        emitOCELEvent('{{ artifact_name | snakeCase }}_success', { input, result, vectorClock: vc.toJSON() });

        return {
          content: [
            {
              type: 'text',
              text: JSON.stringify(result, null, 2)
            }
          ]
        };
      } catch (error) {
        span.recordException(error);
        emitOCELEvent('{{ artifact_name | snakeCase }}_error', { error: error.message });
        return {
          content: [
            {
              type: 'text',
              text: JSON.stringify({
                error: error.message,
                tool: '{{ artifact_name | snakeCase }}'
              }, null, 2)
            }
          ],
          isError: true
        };
      } finally {
        span.end();
      }
    });
    {% else -%}
    // Dachshund: Direct execution with minimal overhead
    try {
      {% if (harden or breed == 'dachshund') -%}
      // L4 HARDENING: Execute through Hardened Facade
      if (context.avmPath) {
        const hardenedVm = new HardenedAtomVM(context.store, context.policyGraph);
        const result = await hardenedVm.execute(
          context.avmPath, 
          context.specKitReceipt, 
          context.agentId, 
          input
        );
        return {
          content: [{ type: 'text', text: JSON.stringify(result, null, 2) }]
        };
      }
      {% endif -%}

      const result = await execute{{ artifact_name | camelCase }}(
        {{ required_params | join(', ') }},
        context
      );

      emitOCELEvent('{{ artifact_name | snakeCase }}_success', { input });

      return {
        content: [{ type: 'text', text: JSON.stringify(result, null, 2) }]
      };
    } catch (error) {
      emitOCELEvent('{{ artifact_name | snakeCase }}_error', { error: error.message });
      return {
        content: [{ type: 'text', text: JSON.stringify({ error: error.message }, null, 2) }],
        isError: true
      };
    }
    {% endif -%}
  }
};

async function execute{{ artifact_name | camelCase }}(
  {% for req in required_params -%}
  {{ req | camelCase }}{% if not loop.last %}, {% endif %}
  {% endfor -%},
  context
) {
  // L5 HARDENING: Atomic State Mutation
  // if (context.vc) await context.store.appendEvent({ type: 'EXECUTE', vectorClock: context.vc }, deltas);
  
  return {
    status: 'success',
    message: '{{ artifact_name }} executed'
  };
}

