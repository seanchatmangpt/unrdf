#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

# UNRDF Pre-commit Quality Gate
# Enforces code quality standards (linting + fast test suite)

echo "🔍 Running pre-commit quality checks..."

# Run lint checks
pnpm lint || exit 1

# Run fast test suite
pnpm test:fast || exit 1

echo "✓ Pre-commit checks passed"
exit 0
