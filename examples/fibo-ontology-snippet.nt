# FIBO Ontology Snippet for JTBD Governance Case Study
# Format: N-Triples (one statement per line)
# Based on Financial Industry Business Ontology (FIBO) from OMG

# Namespace declarations (in comments for reference)
# PREFIX fibo: <http://www.omg.org/spec/EDMC-FIBO/FBC/>
# PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
# PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
# PREFIX sh: <http://www.w3.org/ns/shacl#>

# ============================================================================
# CLASS DEFINITIONS
# ============================================================================

<http://www.omg.org/spec/EDMC-FIBO/FBC/Trade> <http://www.w3.org/1999/02/22-rdf-syntax-ns#type> <http://www.w3.org/2000/01/rdf-schema#Class> .
<http://www.omg.org/spec/EDMC-FIBO/FBC/Trade> <http://www.w3.org/2000/01/rdf-schema#label> "Trade" .
<http://www.omg.org/spec/EDMC-FIBO/FBC/Trade> <http://www.w3.org/2000/01/rdf-schema#comment> "A financial transaction involving exchange of securities or derivatives" .

<http://www.omg.org/spec/EDMC-FIBO/FBC/FinancialTransaction> <http://www.w3.org/1999/02/22-rdf-syntax-ns#type> <http://www.w3.org/2000/01/rdf-schema#Class> .
<http://www.omg.org/spec/EDMC-FIBO/FBC/FinancialTransaction> <http://www.w3.org/2000/01/rdf-schema#label> "Financial Transaction" .

<http://www.omg.org/spec/EDMC-FIBO/FBC/Counterparty> <http://www.w3.org/1999/02/22-rdf-syntax-ns#type> <http://www.w3.org/2000/01/rdf-schema#Class> .
<http://www.omg.org/spec/EDMC-FIBO/FBC/Counterparty> <http://www.w3.org/2000/01/rdf-schema#label> "Counterparty" .
<http://www.omg.org/spec/EDMC-FIBO/FBC/Counterparty> <http://www.w3.org/2000/01/rdf-schema#comment> "Party to a transaction or financial agreement" .

<http://www.omg.org/spec/EDMC-FIBO/FBC/LiquidityAccount> <http://www.w3.org/1999/02/22-rdf-syntax-ns#type> <http://www.w3.org/2000/01/rdf-schema#Class> .
<http://www.omg.org/spec/EDMC-FIBO/FBC/LiquidityAccount> <http://www.w3.org/2000/01/rdf-schema#label> "Liquidity Account" .

<http://www.omg.org/spec/EDMC-FIBO/FBC/ComplianceAuditEntry> <http://www.w3.org/1999/02/22-rdf-syntax-ns#type> <http://www.w3.org/2000/01/rdf-schema#Class> .
<http://www.omg.org/spec/EDMC-FIBO/FBC/ComplianceAuditEntry> <http://www.w3.org/2000/01/rdf-schema#label> "Compliance Audit Entry" .

