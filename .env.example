# UNRDF Development Environment Configuration Template
# Copy this file to .env.local and fill in with your local values
# DO NOT commit secrets to version control

# ==============================================================================
# OTEL (OpenTelemetry) Configuration
# ==============================================================================
OTEL_EXPORTER_JAEGER_ENDPOINT=http://localhost:14250
OTEL_SERVICE_NAME=unrdf-cli
OTEL_LOG_LEVEL=info
OTEL_TRACES_SAMPLER=always_on
OTEL_METRICS_EXPORT_INTERVAL=60000
OTEL_SPAN_ATTRIBUTE_COUNT_LIMIT=128

# ==============================================================================
# RDF Store Configuration
# ==============================================================================
UNRDF_BASE_IRI=http://example.org/
UNRDF_STORE_PATH=.unrdf-store.nq
UNRDF_STORE_TYPE=oxigraph
UNRDF_STORE_READONLY=false

# ==============================================================================
# KGC Sidecar Configuration
# ==============================================================================
KGC_SIDECAR_ENDPOINT=localhost:50051
KGC_SIDECAR_TIMEOUT=3000
KGC_SIDECAR_RETRY_ATTEMPTS=3
KGC_SIDECAR_RETRY_DELAY=1000
KGC_SIDECAR_TLS_ENABLED=false

# ==============================================================================
# KGC Sidecar V2 Configuration (Graceful Degradation)
# ==============================================================================
# Feature flag to enable v2 client with circuit breaker and health checks
KGC_SIDECAR_V2_ENABLED=false

# Health Check Configuration
KGC_SIDECAR_HEALTH_CHECK_INTERVAL=5000
KGC_SIDECAR_HEALTH_CHECK_TIMEOUT=100
KGC_SIDECAR_HEALTH_CHECK_RETRIES=3

# Circuit Breaker Configuration
KGC_SIDECAR_CIRCUIT_BREAKER_THRESHOLD=3
KGC_SIDECAR_CIRCUIT_BREAKER_TIMEOUT=30000
KGC_SIDECAR_CIRCUIT_BREAKER_HALF_OPEN_REQUESTS=3

# Fallback Configuration
KGC_SIDECAR_FALLBACK_MODE=local
KGC_SIDECAR_FALLBACK_AUTO_RECOVER=true

# Retry Configuration (Exponential Backoff)
KGC_SIDECAR_RETRY_MAX_ATTEMPTS=3
KGC_SIDECAR_RETRY_INITIAL_DELAY=100
KGC_SIDECAR_RETRY_MAX_DELAY=1600
KGC_SIDECAR_RETRY_MULTIPLIER=2

# Connection Pool Configuration
KGC_SIDECAR_POOL_MIN_CONNECTIONS=2
KGC_SIDECAR_POOL_MAX_CONNECTIONS=10
KGC_SIDECAR_POOL_IDLE_TIMEOUT=60000

# ==============================================================================
# Policy Configuration
# ==============================================================================
UNRDF_POLICY_DIR=.unrdf/policies
UNRDF_DEFAULT_POLICY=default
UNRDF_POLICY_VALIDATION=strict
UNRDF_POLICY_CACHE_ENABLED=true

# ==============================================================================
# Redis Cache Configuration
# ==============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_CACHE_TTL=3600
REDIS_MAX_RETRIES=3
REDIS_RETRY_DELAY=500
REDIS_CONNECTION_POOL_SIZE=10

# ==============================================================================
# PostgreSQL Lockchain Configuration
# ==============================================================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=unrdf
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_MAX_CONNECTIONS=20
POSTGRES_IDLE_TIMEOUT=30000

# ==============================================================================
# Performance Configuration
# ==============================================================================
CONCURRENT_QUERY_LIMIT=10
MAX_IMPORT_SIZE_MB=100
BATCH_INSERT_SIZE=1000
QUERY_TIMEOUT_MS=30000
CACHE_MAX_SIZE_MB=512

# ==============================================================================
# Security Configuration
# ==============================================================================
ENABLE_AUDIT_LOG=true
AUDIT_LOG_PATH=.unrdf/logs/audit.log
MAX_QUERY_COMPLEXITY=1000
ENABLE_QUERY_SANITIZATION=true

# ==============================================================================
# Feature Flags
# ==============================================================================
ENABLE_KNOWLEDGE_HOOKS=true
ENABLE_DARK_MATTER=true
ENABLE_CRYPTOGRAPHIC_PROVENANCE=true
ENABLE_METRICS_DASHBOARD=false

# ==============================================================================
# Logging Configuration
# ==============================================================================
LOG_LEVEL=info
LOG_FORMAT=json
LOG_OUTPUT=stdout
LOG_FILE_PATH=.unrdf/logs/unrdf.log
LOG_ROTATION_SIZE_MB=50
LOG_RETENTION_DAYS=30
