        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "$${DS_PROMETHEUS}" },
          "editorMode": "code",
          "expr": "histogram_quantile(0.95, sum(rate(otelcol_exporter_sent_spans{service_name=~\"unrdf.*\"}[$__rate_interval]) by (le)) * 1000",
          "legendFormat": "P95 Trace Latency",
          "range": true
        }
      ],
      "title": "Trace Latency (P95)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "$${DS_PROMETHEUS}" },
