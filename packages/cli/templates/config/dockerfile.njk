---
to: "Dockerfile"
description: "Generate Dockerfile for containerized applications"
category: config
requires:
  - app_name
variables:
  app_name: "Application name"
mode: overwrite
---

# {{ app_name | default("codemanufactory") | title }} Dockerfile

FROM node:20-alpine

WORKDIR /app

COPY package*.json ./
RUN npm ci --only=production

COPY . .

EXPOSE {{ port | default("8080") }}

HEALTHCHECK --interval=30s --timeout=3s --start-period=5s --retries=3 \
    CMD wget -qO- http://localhost:{{ port | default("8080") }}/health || exit 1

CMD ["node", "dist/index.js"]
