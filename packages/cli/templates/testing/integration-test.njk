---
to: "test/integration/{{ test_name }}.test.js"
description: "Generate integration test with real dependencies"
category: testing
requires:
  - test_name
variables:
  test_name: "Name of the integration test suite"
  system_under_test: "System or service being tested"
  dependencies: "Array of external dependencies (database, api, etc.)"
  fixtures: "Array of test fixtures (name, data)"
  test_cases: "Array of integration test cases"
  setup_timeout: "Setup timeout in ms (default: 10000)"
  teardown_timeout: "Teardown timeout in ms (default: 5000)"
  language: "Programming language (javascript, python, go, rust)"
mode: overwrite



---






{% if language == "javascript" or language == "typescript" %}
import { describe, it, expect, beforeAll, afterAll, beforeEach, afterEach } from '@jest/globals';
import { {{ system_under_test }} } from '../src/{{ system_under_test | lower }}';

describe('{{ test_name }} Integration Tests', () => {
  let dbConnection;
  let apiClient;

  beforeAll(async () => {
    // Setup all dependencies
    console.log('Setting up integration test environment...');
    dbConnection = await setupDatabase();
    apiClient = await setupApiClient();
  }, {{ setup_timeout | default(10000) }});

  afterAll(async () => {
    // Cleanup all dependencies
    console.log('Tearing down integration test environment...');
    await teardownDatabase(dbConnection);
    await teardownApiClient(apiClient);
  }, {{ teardown_timeout | default(5000) }});

  beforeEach(async () => {
    // Reset fixtures before each test
    await loadFixtures(dbConnection);
  });

  afterEach(async () => {
    // Cleanup after each test
    await clearTestData(dbConnection);
  });

{% for test_case in test_cases | default([{name: "creates user", description: "should create user in database", setup: "seed user data", action: "call API", expected: "user created"}]) %}
  it('{{ test_case.description | default(test_case.name) }}', async () => {
    // Setup
    {% if test_case.setup %}
    await {{ test_case.setup }}();
    {% endif %}

    // Action
    {% if test_case.action == "call API" %}
    const response = await apiClient.{{ test_case.api_method | default("post") }}({
      endpoint: '{{ test_case.endpoint | default("/api/users") }}',
      data: {{ test_case.data | default("{}") }}
    });
    {% endif %}

    // Expected
    {% if test_case.expected == "user created" %}
    expect(response.status).toBe(201);
    expect(response.data.id).toBeDefined();
    expect(response.data.name).toBe('{{ test_case.expected_name | default("Test User") }}');
    {% endif %}
  });
{% endfor %}

  // Helper functions
  async function setupDatabase() {
    // Connect to test database
    console.log('Connecting to test database...');
    // Return database connection
    return {};
  }

  async function setupApiClient() {
    // Initialize API client
    console.log('Initializing API client...');
    // Return API client
    return {};
  }

  async function teardownDatabase(db) {
    // Close database connection
    console.log('Closing database connection...');
  }

  async function teardownApiClient(client) {
    // Close API client
    console.log('Closing API client...');
  }

  async function loadFixtures(db) {
    // Load test fixtures
    console.log('Loading test fixtures...');
    {% for fixture in fixtures | default([]) %}
    await db.query(`
      INSERT INTO {{ fixture.table | default("test_data") }} (name, value)
      VALUES ('{{ fixture.name }}', '{{ fixture.value }}')
    `);
    {% endfor %}
  }

  async function clearTestData(db) {
    // Clear test data
    console.log('Clearing test data...');
    await db.query('DELETE FROM test_data');
  }
});

