curl -X POST https://events.pagerduty.com/v2/enqueue \
  -H "Content-Type: application/json" \
  -d '{
    "routing_key": "YOUR_TEST_KEY",
    "event_action": "trigger",
    "payload": {
      "summary": "Test incident",
      "severity": "info"
    }
  }'
```

