### Installation

```bash
# Clone the repository
git clone <repository-url> {{ project_name | lower }}
cd {{ project_name | lower }}

{% if 'Go' in tech_stack %}
# Install Go dependencies
go mod download

# Run the server
go run main.go
{% endif %}

{% if 'Elixir' in tech_stack %}
# Install dependencies
mix deps.get

# Setup database
mix ecto.setup

# Start Phoenix server
mix phx.server
{% endif %}

{% if 'Rust' in tech_stack %}
# Build the project
cargo build

# Run tests
cargo test
{% endif %}

{% if 'SvelteKit' in tech_stack %}
# Install dependencies
pnpm install

# Start development server
pnpm dev
{% endif %}
```

