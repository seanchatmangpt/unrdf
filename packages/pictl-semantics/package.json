{
  "name": "@unrdf/pictl-semantics",
  "version": "0.0.0-agnostic",
  "description": "PICTL Semantics Integration with @unrdf Federation - Ontology-driven process mining with cryptographic quorum consensus",
  "type": "module",
  "main": "src/index.mjs",
  "exports": {
    ".": "./src/index.mjs",
    "./quorum": "./src/quorum.mjs",
    "./ontology-loader": "./src/ontology-loader.mjs",
    "./result-validator": "./src/result-validator.mjs"
  },
  "sideEffects": false,
  "files": [
    "src/",
    "dist/",
    "data/",
    "README.md",
    "INTEGRATION.md",
    "LICENSE"
  ],
  "scripts": {
    "test": "vitest run --coverage",
    "test:fast": "vitest run --coverage",
    "test:watch": "vitest --coverage",
    "build": "unbuild || true",
    "lint": "eslint src/ test/ --max-warnings=0",
    "lint:fix": "eslint src/ test/ --fix",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "clean": "rm -rf dist/ .nyc_output/ coverage/",
    "dev": "echo 'Development mode for @unrdf/pictl-semantics'"
  },
  "keywords": [
    "rdf",
    "pictl",
    "process-mining",
    "federation",
    "quorum",
    "consensus",
    "ontology"
  ],
  "dependencies": {
    "@comunica/query-sparql": "^3.2.4",
    "@opentelemetry/api": "^1.9.0",
    "@rdfjs/data-model": "^2.1.1",
    "@unrdf/core": "workspace:*",
    "@unrdf/federation": "workspace:*",
    "hash-wasm": "^4.11.0",
    "n3": "^1.26.0",
    "rdf-canonize": "^5.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@unrdf/test-utils": "workspace:*",
    "vitest": "^4.0.15"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/unrdf/unrdf.git",
    "directory": "packages/pictl-semantics"
  },
  "bugs": {
    "url": "https://github.com/unrdf/unrdf/issues"
  },
  "homepage": "https://github.com/unrdf/unrdf#readme",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  }
}
