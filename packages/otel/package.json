{
  "name": "@unrdf/otel",
  "version": "26.4.4",
  "description": "OpenTelemetry semantic convention constants for UNRDF, generated by OTel Weaver",
  "type": "module",
  "main": "./src/index.mjs",
  "exports": {
    ".": "./src/index.mjs",
    "./attributes": "./src/generated/attributes.mjs",
    "./metrics": "./src/generated/metrics.mjs"
  },
  "files": [
    "src/"
  ],
  "scripts": {
    "generate": "cd ../../otel && weaver registry generate --registry registry/ js ../packages/otel/src/generated/",
    "check": "cd ../../otel && weaver registry check --registry registry/"
  },
  "keywords": [
    "opentelemetry",
    "otel",
    "semantic-conventions",
    "rdf",
    "unrdf"
  ],
  "license": "MIT",
  "dependencies": {
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/semantic-conventions": "^1.28.0"
  }
}
