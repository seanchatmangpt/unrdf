{
  "name": "@unrdf/otel",
  "version": "26.4.9",
  "description": "OpenTelemetry integration for UNRDF using pm4py-rust telemetry infrastructure",
  "type": "module",
  "main": "./src/index.mjs",
  "exports": {
    ".": "./src/index.mjs",
    "./attributes": "./src/generated/attributes.mjs",
    "./metrics": "./src/generated/metrics.mjs",
    "./pm4py": "./src/pm4py.mjs",
    "./monitoring": "./src/monitoring.mjs",
    "./validation": "./src/validation/index.mjs",
    "./collector-config": "./deploy/otel-collector-config.yaml"
  },
  "files": [
    "src/",
    "deploy/"
  ],
  "scripts": {
    "generate:powl": "node ../../otel/scripts/powl-to-weaver.mjs --powl-ast-dir ../../ostar/artifacts/powl --skip-check true 2>/dev/null || true",
    "generate": "pnpm run generate:powl && cd ../../otel && weaver registry generate --registry registry/ js ../packages/otel/src/generated/",
    "check": "cd ../../otel && weaver registry check --registry registry/",
    "sync:pm4py": "node scripts/sync-pm4py-otel.mjs",
    "test": "vitest run",
    "test:validation": "vitest run test/validation/"
  },
  "keywords": [
    "opentelemetry",
    "otel",
    "semantic-conventions",
    "rdf",
    "unrdf",
    "pm4py",
    "telemetry",
    "monitoring"
  ],
  "license": "MIT",
  "dependencies": {
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/semantic-conventions": "^1.28.0"
  },
  "peerDependencies": {
    "pm4py": ">=2.7.0"
  },
  "peerDependenciesMeta": {
    "pm4py": {
      "optional": true
    }
  }
}
