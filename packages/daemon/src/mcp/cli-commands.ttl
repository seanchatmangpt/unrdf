  cli:cliPath "template extract" ;
  cli:hasArgument [ a cli:Argument ; cli:argName "file" ; cli:argType "string" ; cli:required true ; cli:argDescription "RDF data file" ] ;
  cli:hasArgument [ a cli:Argument ; cli:argName "subject" ; cli:argType "string" ; cli:required false ; cli:argDescription "Subject URI" ] ;
  cli:hasArgument [ a cli:Argument ; cli:argName "format" ; cli:argType "string" ; cli:required false ; cli:argDescription "Output format (json|yaml|table)" ; cli:defaultValue "json" ] .


