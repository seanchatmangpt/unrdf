  cli:hasArgument [ a cli:Argument ; cli:argName "batch" ; cli:argType "boolean" ; cli:required false ; cli:argDescription "Batch mode" ] ;
  cli:hasArgument [ a cli:Argument ; cli:argName "classUri" ; cli:argType "string" ; cli:required false ; cli:argDescription "Class URI filter" ] ;
  cli:hasArgument [ a cli:Argument ; cli:argName "sparql" ; cli:argType "string" ; cli:required false ; cli:argDescription "SPARQL query" ] ;
  cli:hasArgument [ a cli:Argument ; cli:argName "dryRun" ; cli:argType "boolean" ; cli:required false ; cli:argDescription "Preview without writing" ] ;
  cli:hasArgument [ a cli:Argument ; cli:argName "force" ; cli:argType "boolean" ; cli:required false ; cli:argDescription "Force overwrite" ] .

