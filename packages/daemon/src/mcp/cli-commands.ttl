  cli:hasArgument [ a cli:Argument ; cli:argName "operation" ; cli:argType "string" ; cli:required true ; cli:argDescription "Operation name" ] ;
  cli:hasArgument [ a cli:Argument ; cli:argName "trigger" ; cli:argType "string" ; cli:required true ; cli:argDescription "Trigger cron expression" ] ;
  cli:hasArgument [ a cli:Argument ; cli:argName "payload" ; cli:argType "string" ; cli:required false ; cli:argDescription "Operation payload" ] ;
  cli:hasArgument [ a cli:Argument ; cli:argName "json" ; cli:argType "boolean" ; cli:required false ; cli:argDescription "Output as JSON" ] .

cli:daemon_status a cli:Command ;
  cli:toolName "daemon_status" ;
  cli:description "Check daemon status and health" ;
  cli:cliPath "daemon status" ;
  cli:hasArgument [ a cli:Argument ; cli:argName "json" ; cli:argType "boolean" ; cli:required false ; cli:argDescription "Output as JSON" ] ;
  cli:hasArgument [ a cli:Argument ; cli:argName "include-metrics" ; cli:argType "boolean" ; cli:required false ; cli:argDescription "Include performance metrics" ] .

cli:daemon_logs a cli:Command ;
  cli:toolName "daemon_logs" ;
  cli:description "View daemon logs" ;
  cli:cliPath "daemon logs" ;
  cli:hasArgument [ a cli:Argument ; cli:argName "follow" ; cli:argType "boolean" ; cli:required false ; cli:argDescription "Follow log output" ] ;
  cli:hasArgument [ a cli:Argument ; cli:argName "filter" ; cli:argType "string" ; cli:required false ; cli:argDescription "Log filter expression" ] ;
  cli:hasArgument [ a cli:Argument ; cli:argName "max-lines" ; cli:argType "number" ; cli:required false ; cli:argDescription "Maximum lines to display" ] ;
  cli:hasArgument [ a cli:Argument ; cli:argName "json" ; cli:argType "boolean" ; cli:required false ; cli:argDescription "Output as JSON" ] .

cli:daemon_config a cli:Command ;
  cli:toolName "daemon_config" ;
  cli:description "View daemon configuration" ;
  cli:cliPath "daemon config" ;
  cli:hasArgument [ a cli:Argument ; cli:argName "json" ; cli:argType "boolean" ; cli:required false ; cli:argDescription "Output as JSON" ] .

cli:daemon_cluster a cli:Command ;
  cli:toolName "daemon_cluster" ;
  cli:description "Manage daemon cluster" ;
  cli:cliPath "daemon cluster" ;
  cli:hasArgument [ a cli:Argument ; cli:argName "json" ; cli:argType "boolean" ; cli:required false ; cli:argDescription "Output as JSON" ] ;
  cli:hasArgument [ a cli:Argument ; cli:argName "include-metrics" ; cli:argType "boolean" ; cli:required false ; cli:argDescription "Include metrics" ] .

# =============================================================================
# INSTANCES — SYNC command (1)
# =============================================================================

cli:sync a cli:Command ;
  cli:toolName "sync" ;
  cli:description "Synchronize and generate code from RDF ontology" ;
  cli:cliPath "sync" ;
  cli:hasArgument [ a cli:Argument ; cli:argName "config" ; cli:argType "string" ; cli:required false ; cli:argDescription "Path to .unrdf.toml config" ] ;
  cli:hasArgument [ a cli:Argument ; cli:argName "dry-run" ; cli:argType "boolean" ; cli:required false ; cli:argDescription "Preview without writing files" ] ;
  cli:hasArgument [ a cli:Argument ; cli:argName "verbose" ; cli:argType "boolean" ; cli:required false ; cli:argDescription "Verbose output" ] ;
  cli:hasArgument [ a cli:Argument ; cli:argName "force" ; cli:argType "boolean" ; cli:required false ; cli:argDescription "Force regeneration" ] ;
  cli:hasArgument [ a cli:Argument ; cli:argName "rule" ; cli:argType "string" ; cli:required false ; cli:argDescription "Run only specified rule" ] ;
  cli:hasArgument [ a cli:Argument ; cli:argName "output" ; cli:argType "string" ; cli:required false ; cli:argDescription "Output format (text or json)" ; cli:defaultValue "text" ] .

