cli:template_generate a cli:Command ;
  cli:toolName "template_generate" ;
  cli:description "Generate files from RDF + Nunjucks template (`--template`). RDF path can be positional or `rdf:` in template frontmatter." ;
  cli:cliPath "template generate" ;
  cli:hasArgument [ a cli:Argument ; cli:argName "file" ; cli:argType "string" ; cli:required false ; cli:argDescription "RDF file (Turtle, N-Triples, N-Quads, …). Optional if template sets `rdf:` in frontmatter." ] ;
  cli:hasArgument [ a cli:Argument ; cli:argName "template" ; cli:argType "string" ; cli:required true ; cli:argDescription "Template .njk path" ] ;
  cli:hasArgument [ a cli:Argument ; cli:argName "outputDir" ; cli:argType "string" ; cli:required false ; cli:argDescription "Output directory for generated files" ; cli:defaultValue "./generated" ] ;
  cli:hasArgument [ a cli:Argument ; cli:argName "subject" ; cli:argType "string" ; cli:required false ; cli:argDescription "Focus subject URI; replaces ?subject in SPARQL when present" ] ;
  cli:hasArgument [ a cli:Argument ; cli:argName "batch" ; cli:argType "boolean" ; cli:required false ; cli:argDescription "One output per instance of `--class-uri`; SPARQL must use ?subject" ; cli:defaultValue "false" ] ;
  cli:hasArgument [ a cli:Argument ; cli:argName "classUri" ; cli:argType "string" ; cli:required false ; cli:argDescription "RDFS/OWL class IRI for batch mode (with `--batch`)" ] ;
  cli:hasArgument [ a cli:Argument ; cli:argName "sparql" ; cli:argType "string" ; cli:required false ; cli:argDescription "SPARQL SELECT (overrides frontmatter `sparql:`)" ] ;
  cli:hasArgument [ a cli:Argument ; cli:argName "dryRun" ; cli:argType "boolean" ; cli:required false ; cli:argDescription "Print paths without writing" ; cli:defaultValue "false" ] ;
  cli:hasArgument [ a cli:Argument ; cli:argName "force" ; cli:argType "boolean" ; cli:required false ; cli:argDescription "Overwrite existing files" ; cli:defaultValue "false" ] .


